#!/usr/bin/env bash

set -euo pipefail

banner() {
  printf '\e[1;38;5;231;48;2;64;160;43m[%s] %-72s\e[0m\n' "$(date '+%H:%M:%S')" "$1"
}
fatal() {
  printf '\e[1;38;5;231;48;2;210;15;57m[%s] %-72s\e[0m\n' "$(date '+%H:%M:%S')" "$1"
  exit 1
}

# what tags are we talking about?
old_tag="$(svu current)"
if [[ "${1:-}" == "--rc" ]]; then
  new_tag="$(svu minor --prerelease rc)"
else
  new_tag="$(svu minor)"
fi

# sanity
[ -n "${GITHUB_TOKEN:-}" ] || fatal "GITHUB_TOKEN is required"
[ -z "$(git status --porcelain)" ] || fatal "git worktree is dirty"
[ -z "$(git tag -l "${new_tag}")" ] || fatal "tag already exists: ${new_tag}"

# confirm
banner "are you sure?"
echo
gum confirm "Release ${old_tag} => ${new_tag}?"

# tag
banner "creating tag ${new_tag}..."
git tag "${new_tag}"
git push origin "${new_tag}"

# goreleaseer
banner "goreleaser..."
goreleaser healthcheck
goreleaser release --clean

# done
banner "✓ release ✓"
