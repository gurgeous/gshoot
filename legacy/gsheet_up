#!/usr/bin/env ruby

#
# Upload a local csv to a Google spreadsheet, creating the doc if needed.
#

require "bundler/inline"

gemfile do
  source "https://rubygems.org"
  gem "csv"
  gem "google-apis-drive_v3"
  gem "google-apis-sheets_v4"
  gem "launchy"
  gem "slop"
  gem "memoist"
  gem "webrick"
end

require "google/api_client/auth/installed_app"
require "google/api_client/auth/storage"
require "google/api_client/auth/storages/file_store"
require "google/api_client/client_secrets"
require "google/apis/drive_v3"
require "google/apis/sheets_v4"
require "forwardable"
require "json"
require "pathname"

class Main
  extend Forwardable
  extend Memoist

  SECRETS = "#{ENV["HOME"]}/.client_secrets.json"
  CREDENTIALS = "#{ENV["HOME"]}/.gsheet_oauth2_rw.json"
  GREEN = "\e[1;38;5;231;48;2;64;160;43m"
  MIME = "application/vnd.google-apps.spreadsheet"
  RED = "\e[1;38;5;231;48;2;210;15;57m"
  RESET = "\e[0m"
  SHEET_PREFIX = "gsheet_up_"
  LAYOUT_PADDING = 20

  attr_reader :options
  def_delegators :options, :csvpath, :docfile, :filter?, :layout?, :numeric?, :open?, :refill?, :replace?, :sheet

  def initialize(options)
    @options = options
  end

  def main
    fatal "not found: #{csvpath}" if !csvpath.exist?
    fatal "csv is empty: #{csvpath}" if rows.empty?

    banner("Creating '#{docfile}'...") if !file
    banner "Uploading #{rows.length} rows to '#{drive_file.name}' / '#{target_sheet_title}'..."

    sheet_id = ensure_sheet
    clear_sheet(sheet_id) if replace?
    resize_sheet(sheet_id)
    paste_sheet(sheet_id, data: csv_data, type: refill? ? "PASTE_VALUES" : "PASTE_NORMAL")
    apply_refill_formats(sheet_id) if refill?
    apply_refill_formulas(sheet_id) if refill?
    clear_padding_formats(sheet_id) if refill?
    apply_filter(sheet_id) if filter?
    apply_numeric(sheet_id) if numeric?
    apply_layout(sheet_id) if layout?

    puts url
    system("open", url, exception: true) if open?
  rescue Google::Apis::Error => e
    fatal format_google_error(e)
  end

  def banner(str, color: GREEN)
    puts "#{color}[#{Time.now.strftime("%H:%M:%S")}] #{str.ljust(72)} #{RESET}"
  end

  def fatal(str)
    banner(str, color: RED)
    exit 1 # rubocop:disable Rails/Exit
  end

  def auth
    storage = Google::APIClient::Storage.new(Google::APIClient::FileStore.new(CREDENTIALS))
    auth = storage.authorize
    auth ||= begin
      secrets = Google::APIClient::ClientSecrets.load(SECRETS)
      flow = Google::APIClient::InstalledAppFlow.new(
        client_id: secrets.client_id,
        client_secret: secrets.client_secret,
        scope: [
          "https://www.googleapis.com/auth/drive",
          "https://www.googleapis.com/auth/spreadsheets",
        ]
      )
      flow.authorize(storage)
    end
    auth
  end
  memoize :auth

  def create_file
    body = Google::Apis::DriveV3::File.new(name: docfile, mime_type: MIME)
    drive.create_file(body)
  end

  def file
    banner "Searching Google Drive for '#{docfile}'..."
    q = "mimeType='#{MIME}' and trashed=false"
    drive.list_files(q:, order_by: "modifiedByMeTime desc,name").files.find { name_match?(_1.name, docfile) }
  end
  memoize :file

  def format_google_error(error)
    details = [error.message]
    details << "status=#{error.status_code}" if error.respond_to?(:status_code) && error.status_code
    body = google_error_body(error)
    details << body if body && body != ""
    "Google API error: #{details.join("\n")}"
  end

  def google_error_body(error)
    body =
      if error.respond_to?(:body) && error.body && error.body != ""
        error.body
      elsif error.respond_to?(:response) && error.response&.body && error.response.body != ""
        error.response.body
      end
    return if !body

    begin
      JSON.pretty_generate(JSON.parse(body))
    rescue JSON::ParserError
      body
    end
  end

  def ensure_sheet
    return ensure_refill_sheet if refill?
    return ensure_replace_sheet if replace?

    if sheet
      add_sheet
    elsif file || !blank_default_sheet?
      add_sheet
    else
      rename_sheet(blank_sheet_id)
    end
  end

  def ensure_replace_sheet
    existing_sheet_id || if !file && blank_default_sheet?
                           rename_sheet(blank_sheet_id)
                         else
                           add_sheet
                         end
  end

  def ensure_refill_sheet
    existing_sheet_id || if !file && blank_default_sheet?
                           rename_sheet(blank_sheet_id)
                         else
                           add_sheet
                         end
  end

  def add_sheet
    request = Google::Apis::SheetsV4::Request.new(
      add_sheet: Google::Apis::SheetsV4::AddSheetRequest.new(
        properties: Google::Apis::SheetsV4::SheetProperties.new(
          title: target_sheet_title,
          index: 0,
          grid_properties: Google::Apis::SheetsV4::GridProperties.new(
            row_count: target_row_count,
            column_count: target_column_count
          )
        )
      )
    )
    response = batch_update(request)
    response.replies.first.add_sheet.properties.sheet_id
  end

  def rename_sheet(sheet_id)
    request = Google::Apis::SheetsV4::Request.new(
      update_sheet_properties: Google::Apis::SheetsV4::UpdateSheetPropertiesRequest.new(
        properties: Google::Apis::SheetsV4::SheetProperties.new(sheet_id:, title: target_sheet_title),
        fields: "title"
      )
    )
    batch_update(request)
    sheet_id
  end

  def clear_sheet(sheet_id)
    request = Google::Apis::SheetsV4::Request.new(
      update_cells: Google::Apis::SheetsV4::UpdateCellsRequest.new(
        range: Google::Apis::SheetsV4::GridRange.new(sheet_id:),
        fields: "*"
      )
    )
    batch_update(request)
  end

  def resize_sheet(sheet_id)
    request = Google::Apis::SheetsV4::Request.new(
      update_sheet_properties: Google::Apis::SheetsV4::UpdateSheetPropertiesRequest.new(
        properties: Google::Apis::SheetsV4::SheetProperties.new(
          sheet_id:,
          grid_properties: Google::Apis::SheetsV4::GridProperties.new(
            row_count: target_row_count,
            column_count: target_column_count
          )
        ),
        fields: "gridProperties.rowCount,gridProperties.columnCount"
      )
    )
    batch_update(request)
  end

  def paste_sheet(sheet_id, data:, type:)
    request = Google::Apis::SheetsV4::Request.new(
      paste_data: Google::Apis::SheetsV4::PasteDataRequest.new(
        coordinate: Google::Apis::SheetsV4::GridCoordinate.new(sheet_id:, row_index: 0, column_index: 0),
        data:,
        delimiter: ",",
        type:
      )
    )
    batch_update(request)
  end

  def apply_filter(sheet_id)
    request = Google::Apis::SheetsV4::Request.new(
      set_basic_filter: Google::Apis::SheetsV4::SetBasicFilterRequest.new(
        filter: Google::Apis::SheetsV4::BasicFilter.new(
          range: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 0,
            end_row_index: row_count,
            start_column_index: 0,
            end_column_index: column_count
          )
        )
      )
    )
    batch_update(request)
  end

  def apply_layout(sheet_id)
    auto_resize = Google::Apis::SheetsV4::Request.new(
      auto_resize_dimensions: Google::Apis::SheetsV4::AutoResizeDimensionsRequest.new(
        dimensions: Google::Apis::SheetsV4::DimensionRange.new(
          sheet_id:,
          dimension: "COLUMNS",
          start_index: 0,
          end_index: column_count
        )
      )
    )
    batch_update(auto_resize)

    widths = sheet_column_widths(sheet_id)
    requests = widths.map do |column_index, pixel_size|
      Google::Apis::SheetsV4::Request.new(
        update_dimension_properties: Google::Apis::SheetsV4::UpdateDimensionPropertiesRequest.new(
          range: Google::Apis::SheetsV4::DimensionRange.new(
            sheet_id:,
            dimension: "COLUMNS",
            start_index: column_index,
            end_index: column_index + 1
          ),
          properties: Google::Apis::SheetsV4::DimensionProperties.new(pixel_size: pixel_size + LAYOUT_PADDING),
          fields: "pixelSize"
        )
      )
    end
    batch_update(*requests)
  end

  def apply_numeric(sheet_id)
    requests = numeric_formats.map do |column_index, pattern|
      Google::Apis::SheetsV4::Request.new(
        repeat_cell: Google::Apis::SheetsV4::RepeatCellRequest.new(
          range: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 1,
            end_row_index: row_count,
            start_column_index: column_index,
            end_column_index: column_index + 1
          ),
          cell: Google::Apis::SheetsV4::CellData.new(
            user_entered_format: Google::Apis::SheetsV4::CellFormat.new(
              number_format: Google::Apis::SheetsV4::NumberFormat.new(type: "NUMBER", pattern:)
            )
          ),
          fields: "userEnteredFormat.numberFormat"
        )
      )
    end
    return if requests.empty?

    batch_update(*requests)
  end

  def apply_refill_formats(sheet_id)
    return if !refill? || existing_sheet_values.length < 2 || row_count <= 1

    requests = existing_csv_columns.map do |column_index|
      Google::Apis::SheetsV4::Request.new(
        copy_paste: Google::Apis::SheetsV4::CopyPasteRequest.new(
          source: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 1,
            end_row_index: 2,
            start_column_index: column_index,
            end_column_index: column_index + 1
          ),
          destination: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 1,
            end_row_index: row_count,
            start_column_index: column_index,
            end_column_index: column_index + 1
          ),
          paste_type: "PASTE_FORMAT",
          paste_orientation: "NORMAL"
        )
      )
    end
    return if requests.empty?

    batch_update(*requests)
  end

  def apply_refill_formulas(sheet_id)
    if !refill?
      banner "Refill formulas: skipped, not in --refill mode"
      return
    end
    if row_count <= existing_data_row_count
      banner "Refill formulas: skipped, no new rows (#{existing_data_row_count} -> #{row_count})"
      return
    end

    banner "Refill formulas: checking non-CSV columns for formulas..."
    requests = refill_formula_columns.filter_map do |column_index|
      next if existing_data_row_count < 2

      banner "Refill formulas: extending column #{column_index + 1} to row #{row_count}"
      Google::Apis::SheetsV4::Request.new(
        copy_paste: Google::Apis::SheetsV4::CopyPasteRequest.new(
          source: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 1,
            end_row_index: existing_data_row_count,
            start_column_index: column_index,
            end_column_index: column_index + 1
          ),
          destination: Google::Apis::SheetsV4::GridRange.new(
            sheet_id:,
            start_row_index: 1,
            end_row_index: row_count,
            start_column_index: column_index,
            end_column_index: column_index + 1
          ),
          paste_type: "PASTE_FORMULA",
          paste_orientation: "NORMAL"
        )
      )
    end
    if requests.empty?
      banner "Refill formulas: no formula columns detected"
      return
    end

    batch_update(*requests)
    banner "Refill formulas: applied #{requests.length} formula extension request(s)"
  end

  def clear_padding_formats(sheet_id)
    requests = []

    requests << Google::Apis::SheetsV4::Request.new(
      repeat_cell: Google::Apis::SheetsV4::RepeatCellRequest.new(
        range: Google::Apis::SheetsV4::GridRange.new(
          sheet_id:,
          start_row_index: row_count,
          end_row_index: target_row_count,
          start_column_index: 0,
          end_column_index: target_column_count
        ),
        cell: Google::Apis::SheetsV4::CellData.new(
          user_entered_format: Google::Apis::SheetsV4::CellFormat.new
        ),
        fields: "userEnteredFormat"
      )
    )

    requests << Google::Apis::SheetsV4::Request.new(
      repeat_cell: Google::Apis::SheetsV4::RepeatCellRequest.new(
        range: Google::Apis::SheetsV4::GridRange.new(
          sheet_id:,
          start_row_index: 0,
          end_row_index: row_count,
          start_column_index: column_count,
          end_column_index: target_column_count
        ),
        cell: Google::Apis::SheetsV4::CellData.new(
          user_entered_format: Google::Apis::SheetsV4::CellFormat.new
        ),
        fields: "userEnteredFormat"
      )
    )

    batch_update(*requests)
  end

  def blank_default_sheet?
    return false if spreadsheet.sheets.length != 1
    values = sheets.get_spreadsheet_values(spreadsheet_id, first_sheet_title).values
    !values || values.empty?
  end
  memoize :blank_default_sheet?

  def next_sheet_title
    numbers = spreadsheet.sheets.filter_map do |sheet|
      title = sheet.properties.title
      title[/^#{Regexp.escape(SHEET_PREFIX)}(\d+)$/o, 1]&.to_i
    end
    "#{SHEET_PREFIX}#{(numbers.max || 0) + 1}"
  end

  def existing_sheet_id
    sheet = spreadsheet.sheets.find { name_match?(_1.properties.title, target_sheet_title) }
    sheet&.properties&.sheet_id
  end

  def existing_sheet_values
    return [] if !existing_sheet_id
    rectangularize(sheets.get_spreadsheet_values(spreadsheet_id, target_sheet_title).values || [])
  end
  memoize :existing_sheet_values

  def existing_sheet_user_values
    return [] if !existing_sheet_data

    row_data = existing_sheet_data.data.first.row_data || []
    values = row_data.map do |row|
      (row.values || []).map { user_entered_cell_value(_1) }
    end
    rectangularize(values)
  end
  memoize :existing_sheet_user_values

  def existing_sheet_data
    return if !existing_sheet_id
    refreshed = sheets.get_spreadsheet(spreadsheet_id, ranges: [target_sheet_title], include_grid_data: true)
    refreshed.sheets.find { _1.properties.sheet_id == existing_sheet_id }
  end
  memoize :existing_sheet_data

  def existing_headers = existing_sheet_values.first || []

  def existing_csv_columns
    csv_headers = rows.first || []
    existing_headers.each_index.select { csv_headers.include?(existing_headers[_1]) }
  end

  def refill_formula_columns
    non_csv_columns = (0...existing_headers.length).to_a - existing_csv_columns
    banner "Refill formulas: non-CSV columns #{non_csv_columns.map { _1 + 1 }.join(", ")}"
    non_csv_columns.select { formula_column?(_1) }
  end

  def formula_column?(column_index)
    return false if !existing_sheet_data || existing_data_row_count < 2

    row_data = existing_sheet_data.data.first.row_data || []
    formulas = []
    saw_formula = false

    (1...existing_data_row_count).each do |row_index|
      value = existing_sheet_values[row_index][column_index]
      next if value.nil? || value == ""

      cell = row_data[row_index]&.values&.[](column_index)
      formula = cell&.user_entered_value&.formula_value
      if !formula || formula == ""
        banner "Refill formulas: column #{column_index + 1} rejected at row #{row_index + 1}, nonblank value is not a formula"
        return false
      end
      formulas << formula
      saw_formula = true
    end

    if saw_formula && !formulas.empty?
      banner "Refill formulas: column #{column_index + 1} accepted"
      true
    else
      banner "Refill formulas: column #{column_index + 1} rejected, no formula cells found"
      false
    end
  end

  def existing_data_row_count
    filter_end = existing_sheet_data&.basic_filter&.range&.end_row_index
    count = filter_end || existing_sheet_values.length
    [count, existing_sheet_values.length].min
  end

  def refill_values
    existing = existing_sheet_values
    return rows if existing.empty?

    existing_headers = existing.first
    csv_headers = rows.first
    validate_headers!(existing_headers, "existing sheet")
    validate_headers!(csv_headers, "csv")

    final_headers = existing_headers.dup
    csv_headers.each { final_headers << _1 if !final_headers.include?(_1) }
    by_header = final_headers.each_with_index.to_h

    final_row_count = [existing.length, rows.length].max
    merged = Array.new(final_row_count) { Array.new(final_headers.length, "") }

    existing_sheet_user_values.each.with_index do |row, row_index|
      row.each.with_index { |value, column_index| merged[row_index][column_index] = value }
    end

    csv_headers.each.with_index do |header, csv_column_index|
      target_column_index = by_header.fetch(header)
      rows.each.with_index do |row, row_index|
        merged[row_index][target_column_index] = row[csv_column_index]
      end
      (rows.length...final_row_count).each do |row_index|
        merged[row_index][target_column_index] = ""
      end
    end

    merged
  end
  memoize :refill_values

  def rectangularize(values)
    max = values.map(&:length).max || 0
    values.map { _1 + [""] * (max - _1.length) }
  end

  def validate_headers!(headers, label)
    headers = headers.reject { _1.nil? || _1 == "" }
    dups = headers.tally.select { _2 > 1 }.keys
    fatal "#{label} has duplicate headers: #{dups.join(", ")}" if !dups.empty?
  end

  def user_entered_cell_value(cell)
    value = cell&.user_entered_value
    return "" if !value
    return value.formula_value if value.formula_value
    return value.string_value if value.string_value
    return value.number_value if !value.number_value.nil?
    return value.bool_value if !value.bool_value.nil?
    return value.error_value if value.error_value
    ""
  end

  def numeric_formats
    data_rows = rows.drop(1)
    return {} if data_rows.empty?

    rows.first.each_index.with_object({}) do |column_index, memo|
      target_column_index = csv_target_columns[column_index]
      values = data_rows.map { _1[column_index] }
      values = values.reject { _1.nil? || _1 == "" }.map(&:to_s)
      next if values.empty?
      next if values.any? { _1.include?(",") }

      if values.all? { /\A-?\d+\z/.match?(_1) }
        memo[target_column_index] = "#,##0"
        next
      end

      next if values.any? { !/\A-?\d+(?:\.\d+)?\z/.match?(_1) }
      next if values.none? { _1.include?(".") }

      precision = values.filter_map { _1[/\.(\d+)\z/, 1]&.length }.max.to_i
      precision = precision.clamp(1, 4)
      memo[target_column_index] = "#,##0.#{"0" * precision}"
    end
  end

  def rows
    banner "Reading #{csvpath}..."
    values = CSV.read(csvpath, encoding: "bom|utf-8")
    rectangularize(values)
  end
  memoize :rows

  def batch_update(*requests)
    sheets.batch_update_spreadsheet(
      spreadsheet_id,
      Google::Apis::SheetsV4::BatchUpdateSpreadsheetRequest.new(requests:)
    )
  end

  def name_match?(lhs, rhs)
    lhs.downcase == rhs.downcase
  end

  def sheet_column_widths(sheet_id)
    refreshed = sheets.get_spreadsheet(spreadsheet_id, ranges: [target_sheet_title], include_grid_data: true)
    sheet = refreshed.sheets.find { _1.properties.sheet_id == sheet_id }
    metadata = sheet.data.first.column_metadata.first(column_count)
    metadata.each.with_index.to_h do |dimension, column_index|
      [column_index, dimension.pixel_size || 100]
    end
  end

  def csv_target_columns
    headers = upload_values.first
    rows.first.map { headers.index(_1) }
  end

  # one-liners
  def blank_sheet_id = spreadsheet.sheets.first.properties.sheet_id
  def column_count = upload_values.first.length
  def csv_data = CSV.generate { |csv| upload_values.each { csv << _1 } }
  def drive = Google::Apis::DriveV3::DriveService.new.tap { _1.authorization = auth }
  def drive_file = file || create_file
  def first_sheet_title = spreadsheet.sheets.first.properties.title
  def row_count = upload_values.length
  def sheets = Google::Apis::SheetsV4::SheetsService.new.tap { _1.authorization = auth }
  def spreadsheet_id = drive_file.id
  def spreadsheet = sheets.get_spreadsheet(drive_file.id)
  def target_column_count = column_count + 2
  def target_row_count = row_count + 2
  def target_sheet_title = sheet || ((replace? || refill?) ? "gsheet_up" : next_sheet_title)
  def upload_values = refill? ? refill_values : rows
  def url = "https://docs.google.com/spreadsheets/d/#{drive_file.id}/edit"
  memoize :csv_data, :csv_target_columns, :drive, :drive_file, :sheets, :spreadsheet, :upload_values
end

#
# OptionParser
#

options = {}.tap do |into|
  parsed = Slop.parse do |o|
    o.banner = "Usage: gsheet_up [options...] <gdocfile> <localfile.csv>"
    o.bool "--filter", "add standard Google Sheets filter"
    o.bool "--layout", "auto-size columns to fit cells"
    o.bool "--numeric", "format obvious numeric columns"
    o.bool "--open", "open the sheet url when done"
    o.bool "--refill", "merge into existing sheet"
    o.bool "--replace", "create/overwrite the destination sheet"
    o.string "--sheet", "destination sheet name"
    o.bool("-h", "--help", "show this help") do
      puts o
      exit
    end
  end
  into.merge!(parsed.to_h)
  if parsed.args.length == 0
    puts "gsheet_up: try 'gsheet_up --help' for more information"
    exit
  end
  into[:docfile], into[:csvpath] = parsed.args
  into[:csvpath] = Pathname(into[:csvpath]).expand_path if into[:csvpath]
  raise Slop::Error, "need <gdocfile> and <localfile.csv>" if parsed.args.length != 2
  raise Slop::Error, "use either --refill or --replace" if into[:refill] && into[:replace]
rescue Slop::Error => ex
  puts "gsheet_up: #{ex.message}"
  puts "gsheet_up: try 'gsheet_up --help' for more information"
  exit 1
end

# Hash => Data
options = Data.define(*options.keys) do
  options.keys.select { options[_1] == true || options[_1] == false }.each do
    alias_method :"#{_1}?", _1
  end
end.new(*options.values)

Main.new(options).main
